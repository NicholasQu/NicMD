{
  "name": "nicmd",
  "version": "1.0.0",
  "description": "Beautiful Markdown Editor for Windows",
  "main": "./out/main/index.js",
  "author": "NicMD",
  "productName": "NicMD",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "electron-vite build && npx copyfiles -f src/main/splash.html out/main/ && electron-builder --win --x64",
    "dist:dated": "powershell -ExecutionPolicy Bypass -File scripts/dist-dated.ps1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "^3.6.0",
    "dayjs": "^1.11.10",
    "electron-store": "^8.2.0",
    "immer": "^10.0.4",
    "lodash": "^4.17.21",
    "lucide-react": "^0.396.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "openai": "^6.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "turndown": "^7.2.4",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/remote": "^2.1.3",
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^2.2.0",
    "postcss": "^8.4.38",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.nicmd.editor",
    "productName": "NicMD",
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "!out/renderer/**/*.map"
    ],
    "win": {
      "icon": "public/icons/icon.ico",
      "artifactName": "NicMD-${version}-${arch}.${ext}",
      "sign": null,
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NicMD",
      "perMachine": false,
      "allowElevation": true,
      "include": "scripts/installer.nsh"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "icon": "public/icon.png",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "icon": "public/icon.png",
        "role": "Editor"
      },
      {
        "ext": "mdx",
        "name": "MDX Document",
        "description": "Markdown JSX Document",
        "icon": "public/icon.png",
        "role": "Editor"
      }
    ]
  }
}
